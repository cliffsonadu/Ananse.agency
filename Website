<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Anansé Creative Haus — We Build Culture</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>
:root {
  --red: #8b1a1a;
  --red-light: rgba(139,26,26,0.15);
  --cream: #ede8df;
  --cream-dim: rgba(237,232,223,0.45);
  --cream-ghost: rgba(237,232,223,0.12);
  --cream-faint: rgba(237,232,223,0.06);
  --black: #070707;
  --black2: #0d0d0d;
  --serif: 'Cormorant Garamond', serif;
  --sans: 'DM Sans', sans-serif;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

html { scroll-behavior: smooth; }

body {
  background: var(--black);
  color: var(--cream);
  font-family: var(--sans);
  overflow-x: hidden;
  cursor: none;
}

/* ── CURSOR ── */
.c-dot {
  width: 7px; height: 7px;
  background: var(--red);
  border-radius: 50%;
  position: fixed; top:0; left:0;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%,-50%);
  transition: transform 0.2s, background 0.3s;
}
.c-ring {
  width: 38px; height: 38px;
  border: 0.5px solid rgba(139,26,26,0.45);
  border-radius: 50%;
  position: fixed; top:0; left:0;
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%,-50%);
  transition: width 0.4s, height 0.4s, border-color 0.4s;
}
body.hovering .c-dot { transform: translate(-50%,-50%) scale(0); }
body.hovering .c-ring { width: 56px; height: 56px; border-color: rgba(139,26,26,0.7); }

/* ── NAV ── */
nav {
  position: fixed; top:0; left:0; right:0;
  z-index: 500;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.6rem 3.5rem;
  background: rgba(7,7,7,0);
  transition: background 0.6s, backdrop-filter 0.6s, padding 0.5s;
}
nav.scrolled {
  background: rgba(7,7,7,0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 1.1rem 3.5rem;
  border-bottom: 0.5px solid var(--cream-faint);
}
.nav-logo {
  font-family: var(--serif);
  font-size: 1.25rem;
  letter-spacing: 0.18em;
  font-weight: 400;
  color: var(--cream);
  opacity: 0;
  animation: fD 1s 0.2s forwards;
}
.nav-links {
  display: flex; gap: 2.8rem;
  list-style: none;
}
.nav-links a {
  font-size: 10px;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(237,232,223,0.38);
  text-decoration: none;
  transition: color 0.35s;
  opacity: 0;
  animation: fD 1s 0.4s forwards;
}
.nav-links a:hover { color: var(--cream); }
.nav-cta {
  opacity: 0;
  animation: fD 1s 0.6s forwards;
}
.btn-outline {
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  border: 0.5px solid rgba(237,232,223,0.22);
  padding: 10px 24px;
  color: var(--cream);
  background: transparent;
  cursor: none;
  font-family: var(--sans);
  transition: all 0.4s;
}
.btn-outline:hover { background: rgba(139,26,26,0.18); border-color: var(--red); }
.btn-solid {
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  background: var(--red);
  border: none;
  padding: 14px 34px;
  color: var(--cream);
  cursor: none;
  font-family: var(--sans);
  transition: all 0.4s;
  position: relative; overflow: hidden;
}
.btn-solid::after {
  content:'';
  position: absolute; inset:0;
  background: rgba(255,255,255,0.07);
  opacity: 0; transition: opacity 0.3s;
}
.btn-solid:hover::after { opacity:1; }

/* ── HERO ── */
.hero {
  position: relative;
  height: 100vh;
  min-height: 600px;
  display: flex; flex-direction: column;
  justify-content: flex-end;
  padding: 0 3.5rem 5rem;
  overflow: hidden;
}
.hero-video-wrap {
  position: absolute; inset:0;
  z-index: 0;
}
.hero-video-wrap video {
  width:100%; height:100%;
  object-fit: cover;
  opacity: 0.45;
}
/* Fallback cinematic bg when no video */
.hero-video-wrap .fallback {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 70% 30%, rgba(100,12,12,0.22) 0%, transparent 65%),
    radial-gradient(ellipse 50% 70% at 20% 80%, rgba(60,8,8,0.15) 0%, transparent 60%),
    linear-gradient(160deg, #130808 0%, #080808 45%, #0a0810 100%);
}
.hero-overlay {
  position: absolute; inset:0; z-index:1;
  background: linear-gradient(
    to top,
    rgba(7,7,7,0.92) 0%,
    rgba(7,7,7,0.45) 40%,
    rgba(7,7,7,0.2) 70%,
    rgba(7,7,7,0.35) 100%
  );
}
.hero-grain {
  position: absolute; inset:0; z-index:2;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events: none;
}
.hero-content { position: relative; z-index:3; max-width: 780px; }
.hero-eyebrow {
  font-size: 9px;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 2rem;
  display: flex; align-items: center; gap: 14px;
  opacity: 0; animation: fU 1.1s 0.9s forwards;
}
.hero-eyebrow::before {
  content:'';
  display: inline-block;
  width: 32px; height: 0.5px;
  background: var(--red);
}
.hero-h1 {
  font-family: var(--serif);
  font-size: clamp(3.8rem, 7.5vw, 7.2rem);
  line-height: 0.97;
  font-weight: 300;
  margin-bottom: 2.2rem;
  overflow: hidden;
}
.hero-h1 .w1 {
  display: block;
  opacity: 0; transform: translateY(40px);
  animation: fU 1.1s 1.05s forwards;
}
.hero-h1 .w2 {
  display: block;
  font-style: italic;
  color: rgba(237,232,223,0.3);
  opacity: 0; transform: translateY(40px);
  animation: fU 1.1s 1.22s forwards;
}
.hero-sub {
  font-size: 13.5px;
  line-height: 1.9;
  color: rgba(237,232,223,0.38);
  max-width: 400px;
  font-weight: 300;
  margin-bottom: 3rem;
  opacity: 0; animation: fU 1.1s 1.4s forwards;
}
.hero-btns {
  display: flex; align-items: center; gap: 2rem;
  opacity: 0; animation: fU 1.1s 1.6s forwards;
}
.ghost-link {
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(237,232,223,0.35);
  cursor: none;
  display: flex; align-items: center; gap: 8px;
  transition: color 0.35s;
}
.ghost-link:hover { color: var(--cream); }
.ghost-link .arr { transition: transform 0.35s; display:inline-block; }
.ghost-link:hover .arr { transform: translateX(5px); }

.hero-scroll {
  position: absolute;
  right: 3.5rem; bottom: 4rem;
  z-index: 3;
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  opacity: 0; animation: fI 1s 2.2s forwards;
}
.scroll-bar {
  width: 0.5px; height: 50px;
  background: linear-gradient(to bottom, rgba(237,232,223,0.25), transparent);
  position: relative; overflow: hidden;
}
.scroll-bar::after {
  content:'';
  position: absolute; top:-100%; left:0;
  width:100%; height:100%;
  background: var(--red);
  animation: scrollAnim 2s 2.5s infinite;
}
@keyframes scrollAnim {
  0%   { top:-100%; opacity:1; }
  100% { top:100%; opacity:0; }
}
.scroll-txt {
  font-size: 8px; letter-spacing:0.3em;
  text-transform: uppercase;
  color: rgba(237,232,223,0.22);
  writing-mode: vertical-rl;
}

/* ── VIDEO PLAY INDICATOR ── */
.hero-video-badge {
  position: absolute;
  left: 3.5rem; bottom: 4.5rem;
  z-index: 3;
  display: flex; align-items: center; gap: 12px;
  opacity: 0; animation: fI 1s 2s forwards;
}
.play-ring {
  width: 44px; height: 44px;
  border: 0.5px solid rgba(237,232,223,0.2);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transition: border-color 0.35s;
}
.play-ring:hover { border-color: rgba(237,232,223,0.6); }
.play-tri {
  width:0; height:0;
  border-left: 8px solid rgba(237,232,223,0.6);
  border-top: 5px solid transparent;
  border-bottom: 5px solid transparent;
  margin-left: 2px;
}
.video-label {
  font-size: 9px; letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(237,232,223,0.28);
}

/* ── TICKER ── */
.ticker {
  border-top: 0.5px solid var(--cream-faint);
  border-bottom: 0.5px solid var(--cream-faint);
  padding: 13px 0; overflow: hidden;
  background: var(--black2);
}
.ticker-inner {
  display: flex; gap: 2.5rem;
  white-space: nowrap;
  animation: tickerMove 24s linear infinite;
  width: max-content;
}
.ticker-word {
  font-size: 9px; letter-spacing: 0.26em;
  text-transform: uppercase;
  color: rgba(237,232,223,0.2);
}
.ticker-gem { color: var(--red); font-size: 7px; vertical-align: middle; }
@keyframes tickerMove { 0%{ transform:translateX(0); } 100%{ transform:translateX(-50%); } }

/* ── SECTIONS SHARED ── */
.s-label {
  font-size: 9px; letter-spacing: 0.3em;
  text-transform: uppercase; color: var(--red);
  margin-bottom: 0.8rem;
}
.s-title {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 300; color: var(--cream);
}

/* ── WORK ── */
.work { padding: 6rem 3.5rem; }
.work-head {
  display: flex; justify-content: space-between;
  align-items: flex-end; margin-bottom: 3rem;
}
.work-grid {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr;
  grid-template-rows: auto auto;
  gap: 4px;
}
.wc {
  position: relative; overflow: hidden;
  background: #111; cursor: none;
}
.wc-img {
  width: 100%; aspect-ratio: 3/3.8;
  object-fit: cover; display: block;
  transition: transform 0.85s cubic-bezier(0.25,0.46,0.45,0.94);
}
.wc.tall .wc-img { aspect-ratio: 2/3.2; }
.wc.sm .wc-img { aspect-ratio: 3/2.4; }
.wc:hover .wc-img { transform: scale(1.06); }

/* Colored placeholders simulating photos */
.wc-ph {
  width:100%; display:block;
  position: relative; overflow: hidden;
  transition: transform 0.85s cubic-bezier(0.25,0.46,0.45,0.94);
}
.wc.tall .wc-ph { aspect-ratio: 2/3.2; }
.wc.sm  .wc-ph { aspect-ratio: 3/2.4; }
.wc:not(.tall):not(.sm) .wc-ph { aspect-ratio: 3/3.8; }
.wc:hover .wc-ph { transform: scale(1.06); }

.wc-ph-inner {
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center;
}
.wc-ph-glyph {
  font-family: var(--serif);
  font-size: 5rem;
  color: rgba(237,232,223,0.04);
  font-style: italic;
  transition: color 0.5s;
}
.wc:hover .wc-ph-glyph { color: rgba(237,232,223,0.07); }

.wc-overlay {
  position: absolute; inset:0;
  background: linear-gradient(to top, rgba(7,7,7,0.9) 0%, rgba(7,7,7,0.3) 40%, transparent 65%);
  opacity: 0; transition: opacity 0.55s;
}
.wc:hover .wc-overlay { opacity:1; }

.wc-info {
  position: absolute; bottom:0; left:0; right:0;
  padding: 2rem 1.4rem 1.4rem;
  transform: translateY(12px); opacity:0;
  transition: all 0.55s cubic-bezier(0.25,0.46,0.45,0.94);
}
.wc:hover .wc-info { transform: translateY(0); opacity:1; }
.wc-cat {
  font-size: 8px; letter-spacing: 0.24em;
  text-transform: uppercase; color: var(--red);
  margin-bottom: 5px;
}
.wc-name {
  font-family: var(--serif);
  font-size: 1.15rem; font-weight:300;
  color: var(--cream); line-height: 1.2;
}

.col2 { display:flex; flex-direction:column; gap:4px; }
.col2 .wc { flex:1; }
.col2 .wc .wc-ph,
.col2 .wc .wc-img { aspect-ratio: unset; min-height: 220px; }

/* ── STATS BAR ── */
.stats {
  display: grid; grid-template-columns: repeat(4,1fr);
  border-top: 0.5px solid var(--cream-faint);
  border-bottom: 0.5px solid var(--cream-faint);
}
.stat {
  padding: 2.8rem 3.5rem;
  border-right: 0.5px solid var(--cream-faint);
}
.stat:last-child { border-right: none; }
.stat-num {
  font-family: var(--serif);
  font-size: clamp(2.5rem, 4vw, 3.8rem);
  font-weight: 300; color: var(--cream);
  line-height: 1; margin-bottom: 0.5rem;
}
.stat-num em { font-style: italic; color: var(--red); }
.stat-label {
  font-size: 10px; letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(237,232,223,0.3);
}

/* ── SERVICES ── */
.services { padding: 6rem 3.5rem; }
.svc-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 0; margin-top: 3.5rem;
  border-top: 0.5px solid var(--cream-faint);
}
.svc-item {
  padding: 2rem 0 2rem 0;
  border-bottom: 0.5px solid var(--cream-faint);
  display: flex; justify-content: space-between;
  align-items: center; cursor: none;
  transition: padding-left 0.4s;
  position: relative;
}
.svc-item::before {
  content:'';
  position: absolute; left:0; top:0; bottom:0;
  width:0; background: var(--red);
  opacity:0.06; transition: width 0.4s;
}
.svc-item:hover::before { width:100%; }
.svc-item:hover { padding-left: 1rem; }
.svc-item:nth-child(odd) { padding-right: 3rem; border-right: 0.5px solid var(--cream-faint); }
.svc-item:nth-child(even) { padding-left: 3rem; }
.svc-item:nth-child(even):hover { padding-left: calc(3rem + 1rem); }
.svc-name {
  font-family: var(--serif);
  font-size: 1.3rem; font-weight:300;
  color: rgba(237,232,223,0.6);
  transition: color 0.35s;
}
.svc-item:hover .svc-name { color: var(--cream); }
.svc-num {
  font-size: 9px; letter-spacing: 0.2em;
  color: rgba(237,232,223,0.18);
  transition: color 0.35s;
}
.svc-item:hover .svc-num { color: var(--red); }

/* ── MANIFESTO ── */
.manifesto {
  padding: 6rem 3.5rem;
  position: relative; overflow: hidden;
  border-top: 0.5px solid var(--cream-faint);
}
.m-glow {
  position: absolute;
  right: -8%; top: -30%;
  width: 55%; height: 160%;
  background: radial-gradient(ellipse, rgba(139,26,26,0.08) 0%, transparent 65%);
  pointer-events: none;
}
.m-layout {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 5rem; align-items: center;
}
.m-left {}
.m-quote-mark {
  font-family: var(--serif);
  font-size: 8rem; line-height: 0.5;
  color: rgba(139,26,26,0.18);
  margin-bottom: 1.5rem;
  font-weight: 300;
}
.m-quote {
  font-family: var(--serif);
  font-size: clamp(1.7rem, 2.8vw, 2.5rem);
  line-height: 1.4; font-weight: 300;
  font-style: italic;
  color: rgba(237,232,223,0.6);
}
.m-quote strong { font-style: normal; color: var(--cream); }
.m-right {
  border-left: 0.5px solid rgba(139,26,26,0.3);
  padding-left: 3rem;
}
.m-body {
  font-size: 13px; line-height: 1.95;
  color: rgba(237,232,223,0.35);
  font-weight: 300; margin-bottom: 2.5rem;
}
.m-cta {
  display: flex; align-items: center; gap: 10px;
  font-size: 10px; letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(237,232,223,0.4);
  cursor: none; transition: color 0.35s;
}
.m-cta:hover { color: var(--cream); }
.m-cta .arr { transition: transform 0.35s; display:inline-block; }
.m-cta:hover .arr { transform: translateX(5px); }

/* ── PROCESS ── */
.process {
  padding: 6rem 3.5rem;
  border-top: 0.5px solid var(--cream-faint);
}
.proc-grid {
  display: grid;
  grid-template-columns: repeat(4,1fr);
  gap: 0; margin-top: 3.5rem;
}
.proc-item {
  padding: 2rem 2rem 2rem 0;
  border-right: 0.5px solid var(--cream-faint);
  position: relative;
}
.proc-item:last-child { border-right: none; padding-right: 0; }
.proc-item:not(:first-child) { padding-left: 2rem; }
.proc-n {
  font-family: var(--serif);
  font-size: 3.5rem; font-weight: 300;
  color: rgba(139,26,26,0.15);
  line-height:1; margin-bottom: 1.2rem;
}
.proc-title {
  font-family: var(--serif);
  font-size: 1.3rem; font-weight:300;
  color: var(--cream); margin-bottom: 0.8rem;
}
.proc-desc {
  font-size: 12px; line-height: 1.8;
  color: rgba(237,232,223,0.3); font-weight:300;
}

/* ── CONTACT CTA ── */
.contact-cta {
  padding: 7rem 3.5rem;
  border-top: 0.5px solid var(--cream-faint);
  position: relative; overflow: hidden;
  text-align: center;
}
.cta-glow {
  position: absolute; inset:0;
  background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(139,26,26,0.07) 0%, transparent 70%);
  pointer-events: none;
}
.cta-label {
  font-size: 9px; letter-spacing: 0.32em;
  text-transform: uppercase; color: var(--red);
  margin-bottom: 1.5rem;
}
.cta-h2 {
  font-family: var(--serif);
  font-size: clamp(2.5rem, 5vw, 5rem);
  font-weight: 300; line-height: 1.1;
  color: var(--cream); margin-bottom: 1.5rem;
}
.cta-h2 em { font-style: italic; color: rgba(237,232,223,0.35); }
.cta-sub {
  font-size: 13px; color: rgba(237,232,223,0.35);
  max-width: 400px; margin: 0 auto 3rem;
  line-height: 1.8; font-weight:300;
}
.cta-btns { display: flex; justify-content: center; gap: 1.5rem; }

/* ── FOOTER ── */
footer {
  border-top: 0.5px solid var(--cream-faint);
  padding: 2rem 3.5rem;
  display: flex; justify-content: space-between; align-items: center;
}
.f-logo {
  font-family: var(--serif);
  font-size: 1.1rem; letter-spacing: 0.15em;
  color: rgba(237,232,223,0.3);
}
.f-copy { font-size: 10px; color: rgba(237,232,223,0.18); letter-spacing: 0.08em; }
.f-links { display: flex; gap: 2rem; }
.f-links a {
  font-size: 9px; letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(237,232,223,0.25);
  text-decoration: none; transition: color 0.3s;
}
.f-links a:hover { color: var(--cream); }

/* ── REVEAL ── */
.rv {
  opacity:0; transform: translateY(36px);
  transition: opacity 0.95s cubic-bezier(0.25,0.46,0.45,0.94),
              transform 0.95s cubic-bezier(0.25,0.46,0.45,0.94);
}
.rv.on { opacity:1; transform:translateY(0); }
.rv.d1 { transition-delay: 0.1s; }
.rv.d2 { transition-delay: 0.22s; }
.rv.d3 { transition-delay: 0.34s; }
.rv.d4 { transition-delay: 0.46s; }

/* ── KEYFRAMES ── */
@keyframes fU { from{opacity:0;transform:translateY(32px);} to{opacity:1;transform:translateY(0);} }
@keyframes fD { from{opacity:0;transform:translateY(-10px);} to{opacity:1;transform:translateY(0);} }
@keyframes fI { from{opacity:0;} to{opacity:1;} }

/* ── MOBILE ── */
@media (max-width: 768px) {
  nav { padding: 1.2rem 1.5rem; }
  nav.scrolled { padding: 0.9rem 1.5rem; }
  .nav-links { display:none; }
  .hero { padding: 0 1.5rem 3.5rem; }
  .work { padding: 4rem 1.5rem; }
  .work-grid { grid-template-columns: 1fr 1fr; }
  .col2 { display: contents; }
  .stats { grid-template-columns: 1fr 1fr; }
  .stat { padding: 1.8rem; }
  .services { padding: 4rem 1.5rem; }
  .svc-grid { grid-template-columns: 1fr; }
  .svc-item:nth-child(odd) { border-right: none; padding-right:0; }
  .svc-item:nth-child(even) { padding-left:0; }
  .svc-item:nth-child(even):hover { padding-left: 1rem; }
